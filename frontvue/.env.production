# 生产环境配置
NODE_ENV=production

# API基础URL
VITE_API_BASE_URL=https://api.example.com

# WebSocket基础URL
VITE_WS_BASE_URL=wss://api.example.com

# 上传文件URL
VITE_UPLOAD_URL=https://api.example.com/media

# 静态资源URL
VITE_STATIC_URL=https://api.example.com/static

# 跨域配置
VITE_CORS_ORIGIN=https://example.com

# JWT配置
VITE_JWT_ACCESS_TOKEN_KEY=access_token
VITE_JWT_REFRESH_TOKEN_KEY=refresh_token 