# Environment variables and secrets
.env

# Python virtual environments
.venv/
venv/
env/

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Django runtime artifacts
logs/
media/
/static/

# Keep default avatar and banner assets
!media/
!media/avatars/
!media/banners/
media/avatars/*
media/banners/*
!media/avatars/default-avatar.svg
!media/banners/default-banner.svg

# Ignore legacy localized asset directories and user uploads
media/avatars1/
media/banners1/

# Data and temporary files
data.json
schools_with_locations.csv
debug_routing.py

# Keep project metadata and lock files
!pyproject.toml
!uv.lock
